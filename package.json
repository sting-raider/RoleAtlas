{
  "name": "role-atlas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run test:unit && npm run build && npm run test:rendered",
    "test:unit": "node scripts/run-ts-tests.mjs",
    "test:rendered": "node --test tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "format:check": "node scripts/check-format.mjs",
    "geography:generate": "node scripts/generate-geography.mjs",
    "registry:validate": "node scripts/validate-registry.mjs",
    "doctor": "node scripts/doctor.mjs",
    "db:generate": "drizzle-kit generate",
    "scout:check": "cargo check --manifest-path services/scout/Cargo.toml",
    "scout:test": "cargo test --manifest-path services/scout/Cargo.toml"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@koshmoney/countries": "^1.0.1-beta.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "countries-and-timezones": "^3.9.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "world-countries": "^5.1.0",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
