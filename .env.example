# Web UI server-to-server connection. Docker Compose overrides this with http://api:8080.
SCOUT_API_URL=http://localhost:8080

# Rust scout
NATS_URL=nats://127.0.0.1:4222
DATABASE_URL=postgres://firstrung:firstrung@127.0.0.1:5432/firstrung
# Optional override. Leave empty to use the maintained default source catalog.
SCOUT_SEEDS=
# Revisit the maintained source catalog every six hours.
RECRAWL_INTERVAL_SECS=21600
SCOUT_USER_AGENT=RoleAtlasScout/0.1 (+https://your-domain.example/crawler; jobs-only)
CRAWL_DELAY_MS=1500
REQUEST_TIMEOUT_SECS=25
MAX_BODY_BYTES=5242880
RUST_LOG=firstrung_scout=info
