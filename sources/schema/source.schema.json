{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "company", "careersUrl", "adapter", "boardId", "endpointUrl", "hiringCountryCodes", "hiringRegionCodes", "knownCityLocations", "opportunityHistory", "remoteHistory", "languages", "status", "lastVerified", "verification", "autoEnqueue", "notes"],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[-:][a-z0-9]+)*$" },
      "company": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "domain"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "domain": { "type": "string", "pattern": "^[a-z0-9.-]+\\.[a-z]{2,}$" }
        }
      },
      "careersUrl": { "type": "string", "format": "uri" },
      "adapter": { "enum": ["greenhouse", "lever", "ashby"] },
      "boardId": { "type": "string", "minLength": 1 },
      "endpointUrl": { "type": "string", "format": "uri" },
      "headquartersCountryCode": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
      "hiringCountryCodes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z]{2}$" } },
      "hiringRegionCodes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]+$" } },
      "knownCityLocations": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 2 } },
      "opportunityHistory": {
        "type": "object", "additionalProperties": false, "required": ["categories", "observedCount"],
        "properties": { "categories": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }, "observedCount": { "type": "integer", "minimum": 0 } }
      },
      "remoteHistory": {
        "type": "object", "additionalProperties": false, "required": ["scopes", "observedCount"],
        "properties": { "scopes": { "type": "array", "uniqueItems": true, "items": { "enum": ["worldwide", "countries", "region", "timezone", "location_restricted", "unspecified"] } }, "observedCount": { "type": "integer", "minimum": 0 } }
      },
      "languages": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$" } },
      "status": { "enum": ["verified", "experimental", "disabled"] },
      "lastVerified": { "type": "string", "format": "date" },
      "verification": {
        "type": "object", "additionalProperties": false, "required": ["method", "result", "observedJobs"],
        "properties": { "method": { "enum": ["complete_public_ats_scan", "manual_fixture_review"] }, "result": { "enum": ["success", "partial", "failed"] }, "observedJobs": { "type": "integer", "minimum": 0 } }
      },
      "proposedBy": { "enum": ["maintainer", "contributor", "ai"] },
      "autoEnqueue": { "type": "boolean" },
      "notes": { "type": "string" }
    }
  }
}
